---
interface Props {
  title: string;
  period: string;
  tags: string[];
  github: string;
  description: string;
}
const { title, period, tags, github, description } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — Erald Shahinas</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Inter+Tight:wght@600;700;800;900&display=swap" rel="stylesheet" />
    <style>
      html { background-color: #fafafa; }
      ::-webkit-scrollbar { width: 5px; }
      ::-webkit-scrollbar-track { background: #f1f5f9; }
      ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 3px; }
    </style>
  </head>
  <body class="bg-bg text-slate-900 font-sans antialiased">
    <!-- Nav -->
    <header class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-md border-b border-slate-100 shadow-sm">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
        <a href="/" style="font-family: 'Inter Tight', Inter, sans-serif;" class="text-sm font-bold tracking-widest text-slate-900 uppercase">ES</a>
        <a href="/#projects" class="flex items-center gap-1.5 text-sm text-slate-500 hover:text-accent transition-colors font-medium">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          All projects
        </a>
      </nav>
    </header>

    <main class="pt-16">
      <!-- Hero -->
      <section class="bg-white py-16 border-b border-slate-100">
        <div class="mx-auto max-w-4xl px-6">
          <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-accent">{period}</p>
          <h1 style="font-family: 'Inter Tight', Inter, sans-serif;" class="mb-5 text-4xl font-black leading-tight text-slate-900 sm:text-5xl">
            {title}
          </h1>
          <p class="mb-8 max-w-2xl text-lg text-slate-500 leading-relaxed">{description}</p>
          <div class="flex flex-wrap items-center gap-4">
            <a
              href={github}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 rounded-xl bg-slate-900 px-5 py-2.5 text-sm font-semibold text-white transition-opacity hover:opacity-80"
            >
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
              </svg>
              View on GitHub
            </a>
            <div class="flex flex-wrap gap-2">
              {tags.map((tag) => (
                <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-xs font-medium text-slate-500">{tag}</span>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- Page content -->
      <section class="py-16">
        <div class="mx-auto max-w-4xl px-6">
          <slot />
        </div>
      </section>
    </main>

    <footer class="border-t border-slate-100 bg-white py-8 text-center text-sm text-slate-400">
      <p>
        <a href="/" class="hover:text-accent transition-colors">← Back to portfolio</a>
        &nbsp;&middot;&nbsp;
        &copy; {new Date().getFullYear()} Erald Shahinas
      </p>
    </footer>
  </body>
</html>
