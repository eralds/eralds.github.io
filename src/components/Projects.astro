---
const projects = [
  {
    title: 'World Model Neural Network Architectures',
    period: 'Sep – Dec 2024',
    tags: ['Reinforcement Learning', 'PyTorch', 'HPC', 'W&B'],
    description:
      'Compared MLP, RNN, and Transformer architectures as world model transition functions in RL environments. Ran large-scale experiments on Aalto\'s Triton HPC cluster and tracked results with Weights & Biases.',
    slug: 'world-model-nn',
  },
  {
    title: 'Automated English Toxicity Detection',
    period: 'Mar – Jun 2024',
    tags: ['NLP', 'BERT', 'LSTM', 'Scikit-learn'],
    description:
      'Benchmarked classical ML (SVM, Random Forests with TF-IDF / Word2Vec) against deep learning approaches (LSTM, BERT) for toxicity classification. BERT-based models achieved the best results.',
    slug: 'toxicity-detection',
  },
  {
    title: 'FolGPT',
    period: 'Jun – Jul 2023',
    tags: ['Flask', 'GPT-4', 'Azure', 'JavaScript'],
    description:
      'Multilanguage voice assistant web app powered by GPT-4 and Azure Speech APIs. Supports conversation in 100+ languages, including many with no existing voice assistant support.',
    slug: 'folgpt',
  },
];
---

<section id="projects" class="bg-white py-24">
  <div class="mx-auto max-w-6xl px-6">
    <div class="reveal mb-14">
      <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-accent">Work</p>
      <h2 style="font-family: 'Inter Tight', Inter, sans-serif;" class="text-3xl font-bold text-slate-900">Projects</h2>
    </div>

    <div class="grid gap-6 md:grid-cols-3">
      {projects.map((project) => (
        <a
          href={`/projects/${project.slug}`}
          class="reveal group flex flex-col rounded-2xl border border-slate-100 bg-white p-6 shadow-sm hover:shadow-md hover:border-blue-100 transition-all"
        >
          <div class="mb-4">
            <h3 class="text-base font-semibold text-slate-900 leading-snug group-hover:text-accent transition-colors">{project.title}</h3>
            <p class="mt-1 text-xs text-slate-400">{project.period}</p>
          </div>
          <p class="mb-5 flex-1 text-sm text-slate-500 leading-relaxed">{project.description}</p>
          <div class="mt-auto">
            <div class="mb-4 flex flex-wrap gap-1.5">
              {project.tags.map((tag) => (
                <span class="rounded-full bg-slate-50 border border-slate-100 px-2.5 py-0.5 text-xs text-slate-500">
                  {tag}
                </span>
              ))}
            </div>
            <span class="inline-flex items-center gap-1 text-sm font-medium text-accent">
              View project
              <svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
