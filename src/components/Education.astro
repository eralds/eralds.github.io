---
const degrees = [
  {
    degree: "Master's in Machine Learning, Data Science and AI",
    school: 'Aalto University',
    location: 'Espoo, Finland',
    period: 'Sep 2023 to Jul 2025',
    honors: 'With Honors',
    courses: ['Reinforcement Learning', 'Deep Learning', 'NLP', 'Computer Vision', 'Probabilistic Machine Learning', 'Data Science'],
  },
  {
    degree: "Bachelor's in Computational Engineering",
    school: 'Aalto University',
    location: 'Espoo, Finland',
    period: 'Sep 2020 to Jun 2023',
    honors: 'With Honors',
    courses: ['Programming Parallel Computers', 'Algorithms & Data Structures', 'Artificial Intelligence', 'Numerical Methods'],
  },
];
---

<section id="education" class="bg-slate-50 py-24">
  <div class="mx-auto max-w-6xl px-6">
    <div class="reveal mb-14">
      <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-accent">Background</p>
      <h2 style="font-family: 'Inter Tight', Inter, sans-serif;" class="text-3xl font-bold text-slate-900">Education</h2>
    </div>

    <div class="grid gap-6 md:grid-cols-2">
      {degrees.map((edu) => (
        <div class="reveal rounded-2xl border border-slate-100 bg-white p-6 md:p-8 shadow-sm">
          <div class="mb-5">
            <h3 class="text-base font-semibold text-slate-900 leading-snug mb-1">{edu.degree}</h3>
            <p class="text-accent text-sm font-medium">{edu.school} &middot; {edu.location}</p>
            <p class="mt-1 text-xs text-slate-400">{edu.period} &middot; {edu.honors}</p>
          </div>
          <div>
            <p class="mb-2.5 text-xs font-semibold uppercase tracking-widest text-slate-400">Key Courses</p>
            <div class="flex flex-wrap gap-1.5">
              {edu.courses.map((c) => (
                <span class="rounded-full bg-slate-50 border border-slate-100 px-2.5 py-0.5 text-xs text-slate-500">{c}</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Notable achievements -->
    <div class="reveal mt-6 rounded-2xl border border-slate-100 bg-white p-6 shadow-sm flex flex-wrap items-center gap-8">
      <div class="flex items-center gap-4">
        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-blue-50 text-accent">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-semibold text-slate-900">7th place out of 364 students</p>
          <p class="text-xs text-slate-400">Programming Parallel Computers, Aalto University</p>
        </div>
      </div>
      <div class="flex items-center gap-4">
        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-blue-50 text-accent">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-semibold text-slate-900">100% Scholarship, 5 consecutive years</p>
          <p class="text-xs text-slate-400">Awarded by Aalto University</p>
        </div>
      </div>
    </div>
  </div>
</section>
