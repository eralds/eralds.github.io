---
const papers = [
  {
    title: 'Safe reinforcement learning for ship energy optimization with LLM-based reward shaping',
    authors: 'Erald Shahinas, Carl Akira King, Udayanto Dwi Atmojo',
    venue: 'IEEE ETFA 2025 — 30th IEEE International Conference on Emerging Technologies and Factory Automation',
    award: 'Best Work in Progress Paper Award',
    description:
      'Developed a proof-of-concept safe RL control system for ship energy optimization, incorporating whitebox simulation, surrogate neural networks, and LLM-generated reward functions.',
    url: 'https://ieeexplore.ieee.org/document/11205530',
  },
  {
    title: 'Exploring Safe Reinforcement Learning Using Safety Shields Derived With System-Theoretic Process Analysis: A Case-Study on a Cruise Ship Hotel System',
    authors: 'Carl Akira King, Erald Shahinas, Udayanto Dwi Atmojo, Valeriy Vyatkin',
    venue: 'IEEE ETFA 2025 · ECML-PKDD 2025 Workshop on AI for Safety-Critical Infrastructures',
    award: null,
    description:
      'Investigated safety shield construction using STPA for a cruise ship hotel system energy management scenario under a safe RL framework.',
    url: 'https://ieeexplore.ieee.org/document/11205793',
  },
];
---

<section id="publications" class="bg-slate-50 py-24">
  <div class="mx-auto max-w-6xl px-6">
    <div class="reveal mb-14">
      <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-accent">Research</p>
      <h2 style="font-family: 'Inter Tight', Inter, sans-serif;" class="text-3xl font-bold text-slate-900">Publications</h2>
    </div>

    <div class="space-y-6">
      {papers.map((paper) => (
        <div class="reveal rounded-2xl border border-slate-100 bg-white p-6 md:p-8 shadow-sm hover:shadow-md transition-shadow">
          <div class="flex flex-wrap items-start justify-between gap-3 mb-4">
            <h3 class="text-base font-semibold text-slate-900 leading-snug max-w-2xl">
              {paper.title}
            </h3>
            {paper.award && (
              <span class="shrink-0 flex items-center gap-1.5 rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold text-accent border border-blue-100">
                <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
                {paper.award}
              </span>
            )}
          </div>
          <p class="mb-1.5 text-sm text-slate-400">{paper.authors}</p>
          <p class="mb-4 text-xs font-medium text-accent">{paper.venue}</p>
          <p class="mb-5 text-sm text-slate-500 leading-relaxed">{paper.description}</p>
          <a
            href={paper.url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-accent hover:underline"
          >
            Read on IEEE Xplore
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
